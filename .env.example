# PostgreSQL connection for nodum. Copy to `.env` and adjust as needed.
# Defaults match docker-compose.yml (host port 5436).
NODUM_DATABASE_URL=postgresql://nodum:nodum@localhost:5436/nodum

# Mark the session cookie Secure (HTTPS-only). Leave unset/0 for local HTTP dev;
# set to 1 behind a TLS-terminating reverse proxy.
# NODUM_COOKIE_SECURE=1
